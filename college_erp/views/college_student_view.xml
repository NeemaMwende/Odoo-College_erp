<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <!--create form view-->
    <record id="college_student_view_form" model="ir.ui.view">
        <field name="name">college.student.view.form</field>
        <field name="model">college.student</field>
        <field name="arch" type="xml">
            <form create="true" edit="false" delete="false">
                <sheet>
                    <field name="image_1920" class="oe_avatar" widget="image"/>
                    <group>
                        <group>
                            <field name="admission_no"/>
                            <field name="admission_date"/>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="email"/>
                            <field name="mother_name"/>
                            <field name="father_name"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="contact_address"/>
                            <field name="same_as_contact" widget="boolean_toggle"/>
                            <span class="o_form_label o_td_label o_address_type fw-bold" invisible="same_as_contact">
                                Permanent Address
                            </span>

                        </group>
                    </group>

                    <!-- Notebook and page-->
                    <notebook>
                        <page string="Permanent Address" name="permanent_address" invisible="same_as_contact">
                            <group>
                                <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" group="base.group_user"/>
                                </div>
                            </group>
                        </page>
                        <page string="Progress Report" name="progress_report">
                        <group>
                            <div class="o_address_format">
                            <field name="street" placeholder="Street..." class="o_address_street"/>
                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                            <field name="city" placeholder="City" class="o_address_city"/>
                            <field name="state_id" class="o_address_state" placeholder="State"/>
                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                            <field name="country_id" placeholder="Country" group="base.group_user"/>
                            </div>
                        </group>
                        </page>
                        <page string="Score summary" name="score_summary">
                        <group>
                            <div class="o_address_format">
                            <field name="street" placeholder="Street..." class="o_address_street"/>
                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                            <field name="city" placeholder="City" class="o_address_city"/>
                            <field name="state_id" class="o_address_state" placeholder="State"/>
                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                            <field name="country_id" placeholder="Country" group="base.group_user"/>
                            </div>
                        </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--window action-->
    <record id="action_college_erp" model="ir.actions.act_window">
        <field name="name">College ERP</field>
        <field name="res_model">college.student</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Student</p>
        </field>
    </record>
</odoo>
