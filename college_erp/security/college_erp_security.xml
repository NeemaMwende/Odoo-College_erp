<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.module.category" id="module_category_college_erp">
        <field name="name">College ERP</field>
        <field name="description">Category for College ERP</field>
    </record>
    <record id="group_college_erp_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="category_id" ref="module_category_college_erp"/>
    </record>
     <record id="group_college_erp_principal" model="res.groups">
        <field name="name">Principal</field>
        <field name="category_id" ref="module_category_college_erp"/>
        <field name="implied_ids" eval="[(4,ref('group_college_erp_teacher'))]"/>
     </record>
</odoo>